# These values are configured in the app's Settings UI.
# This file is just for reference — the app stores settings in its SQLite database.

# Gmail account used to SEND sale alerts
GMAIL_USER=yourname@gmail.com

# App Password (not your regular Gmail password)
# Create one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the Gmail account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address to RECEIVE sale alerts
NOTIFICATION_EMAIL=mcastroebner@gmail.com
